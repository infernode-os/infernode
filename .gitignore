# Runtime overlay root — populated by emu at boot, never tracked
n/local/

# Phase 1c (INFR-110) APK build artefacts. The Inferno-side mkfile
# chain stages these into the Android-app tree at build time; they
# are produced fresh by ./build-android-apk.sh on every invocation.
android-app/app/src/main/jniLibs/arm64-v8a/libemu.so
android-app/app/src/main/jniLibs/arm64-v8a/libSDL3.so
android-app/app/src/main/assets/inferno-root/
emu/Android/libemu.so
emu/Android/o.emu
build-android-apk.ndk.log

# Gradle local state. The wrapper jar + properties + the gradlew
# scripts are tracked (they are the build entry point); .gradle/ and
# build/ are per-build caches that don't belong in git. local.properties
# carries the host's sdk.dir, which is per-machine.
android-app/.gradle/
android-app/build/
android-app/app/build/
android-app/local.properties

# Release signing secrets — NEVER commit. The upload keystore and the
# properties file naming it stay on the signer's machine / in CI secrets.
# keystore.properties.example is the tracked template.
android-app/keystore.properties
*.jks
*.keystore

# Multi-arch APK build artefacts (INFR-67 x86_64 NDK target).
android-app/app/src/main/jniLibs/x86_64/libemu.so
android-app/app/src/main/jniLibs/x86_64/libSDL3.so
build-android-apk.ndk-arm64-v8a.log
build-android-apk.ndk-x86_64.log

# node interop harness artifacts (generated; never commit keys)
usr/inferno/keyring/interop-*
tmp/interop_pulled_*
dis/interop_node_server.dis
dis/interop_node_client.dis
/dis/tests/stress/
/dis/tests/bench/

# Local video/image capture from codec testing (kept on disk, never committed)
*.m1v
*.y4m
scratchrun/

# 2FA POC scratch — belongs with the YubiKey workstream, not the main tree
tools/2fa-poc/

# video demo media — regenerable, see demo-video.sh header
/video-demo-media/
