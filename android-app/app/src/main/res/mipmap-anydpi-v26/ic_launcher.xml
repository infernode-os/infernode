<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive launcher icon (API 26+). minSdk is 28, so this is always used;
     the legacy mipmap-*/ic_launcher.png are fallback only. Background is the
     same black as the icon's own field, so the launcher mask blends; the
     orange flame sits inside the 66dp safe zone. -->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/ic_launcher_background" />
    <foreground android:drawable="@mipmap/ic_launcher_foreground" />
</adaptive-icon>
