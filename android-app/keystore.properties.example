# Release upload-key credentials for Google Play (Play App Signing).
#
# Copy this file to `keystore.properties` (same directory) and fill in the
# real values. `keystore.properties` is gitignored — it must NEVER be
# committed. The build reads it via app/build.gradle.kts.
#
# Generate the upload keystore once (keep the file + passwords in a password
# manager, not in the repo):
#
#   keytool -genkeypair -v -keystore infernode-upload.jks \
#       -keyalg RSA -keysize 4096 -validity 10000 -alias upload
#
# Then point storeFile at the absolute path of that .jks.
#
# CI uses the matching env vars instead of this file:
#   INFERNODE_UPLOAD_KEYSTORE           (path to the .jks)
#   INFERNODE_UPLOAD_KEYSTORE_PASSWORD
#   INFERNODE_UPLOAD_KEY_ALIAS          (defaults to "upload" if unset)
#   INFERNODE_UPLOAD_KEY_PASSWORD

storeFile=/absolute/path/to/infernode-upload.jks
storePassword=CHANGEME
keyAlias=upload
keyPassword=CHANGEME
