TARG=\
	position-table.dis\
	signal-feed.dis\
	risk-gauge.dis\
	alert-watcher.dis\
	geo-fixture.dis\
	geo-map.dis\
	llm-recorder.dis\
	llm-context.dis\
	llm-sessions.dis\
	sysmon-svc.dis\
	cpu-gauge.dis\
	mem-gauge.dis\
	net-gauge.dis\
	proc-list.dis\
	tk-gallery.dis\
	tk-notes.dis\
	video-ctl.dis\
	video-pane.dis\

SYSMODULES=\
	sys.m\
	draw.m\
	geoproj.m\
	lucitheme.m\
	math.m\
	matrix.m\
	matrixtk.m\
	tk.m\

DISBIN=$ROOT/dis/matrix

<$ROOT/mkfiles/mkdis

# video-pane reuses the mpeg render path (Mpegio/Remap/YCbCr), whose
# interface lives with the decoder in appl/mpeg rather than module/.
LIMBOFLAGS=$LIMBOFLAGS -I$ROOT/appl/mpeg

# Regenerate the library's whatis-style module index from the NAME
# lines of lib/matrix/man/*.  Run after adding or renaming a module
# man page; the generated lib/matrix/index is checked in.
index:V:
	sh $ROOT/tools/matrix-makewhatis.sh $ROOT
