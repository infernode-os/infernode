# Headless o.emu for Android arm64, cross-compiled via NDK.
# Mirrors emu/Linux/mkfile-g but targets SYSTARG=Android so output
# lands in Android/arm64/ and the binary links against Bionic at the
# Android system path, not Termux's $PREFIX/lib.

SYSTARG=Android
<$ROOT/mkconfig
SYSTARG=Android

#Configurable parameters

CONF=emu			#default configuration
CONFLIST=emu
CLEANCONFLIST=

INSTALLDIR=$ROOT/$SYSTARG/$OBJTYPE/bin	#path of directory where kernel is installed

#end configurable parameters


<| $SHELLNAME ../port/mkdevlist  $CONF	#sets $IP, $DEVS, $PORT, $LIBS
<mkfile-$OBJTYPE	# sets $ARCHFILES

OBJ=\
	asm-$OBJTYPE.$O\
	$ARCHFILES\
	os.$O\
	kproc-pthreads.$O\
	segflush-$OBJTYPE.$O\
	stubs-headless.$O\
	$CONF.root.$O\
	lock.$O\
	$DEVS\
	$PORT\

HFILES=\

CFLAGS=\
	'-DROOT="'$ROOT'"'\
	-DEMU -I. -I../port\
	-I$ROOT/$SYSTARG/$OBJTYPE/include\
	-I$ROOT/include\
	-I$ROOT/libinterp\
	$CTHREADFLAGS $CFLAGS $EMUOPTIONS\

KERNDATE=`{$NDATE}

# Headless build â€” no X11, no SDL3. AAudio backend (audio-aaudio.c)
# replaces the Phase 0 no-op stub.
SYSLIBS=\
	-lm\
	-laaudio\

# Note: no -lpthread on Android. Bionic merges pthread into libc.

default:V:	$O.$CONF

# Build $CONF.$O (emu.o) as its own rule so both the executable and
# the libemu.so target below can depend on it. Previously the compile
# was inlined in the o.emu recipe body, which meant the libemu.so
# rule fell back to the generic `%.$O: %.c` meta-rule â€” and that
# meta-rule does not pass -DKERNDATE, so emu.c failed with
# `use of undeclared identifier 'KERNDATE'`.
$CONF.$O: $CONF.c $CONF.root.h
	$CC $CFLAGS '-DKERNDATE='$KERNDATE $CONF.c

$O.$CONF:	$OBJ $CONF.$O
	$LD $LDFLAGS -o $target $OBJ $CONF.$O $LIBFILES $SYSLIBS

# Phase 1c (INFR-110) â€” shared library variant for the APK build.
#
# Same .o set as o.emu, plus the JNI wrapper that exposes
# Java_io_infernode_Emu_run, linked -shared. android-app/.../build.gradle.kts
# picks libemu.so up from src/main/jniLibs/arm64-v8a/; the
# build-android-apk.sh driver copies it there before invoking Gradle.
#
# The JNI bridge source lives next to the Android-app project rather than
# under emu/Android/ because conceptually it belongs to the APK layer,
# not to the kernel target. The relative path keeps the mkfile honest
# about that division.
JNI_SRC=../../android-app/app/src/main/cpp/jni-emu.c

jni-emu.$O: $JNI_SRC
	$CC $CFLAGS '-DKERNDATE='$KERNDATE -o jni-emu.$O $JNI_SRC

libemu.so: $OBJ $CONF.$O jni-emu.$O
	$LD -shared $LDFLAGS -o $target $OBJ $CONF.$O jni-emu.$O $LIBFILES $SYSLIBS

libemu:V: libemu.so

install:V: $O.$CONF
	mkdir -p $INSTALLDIR
	cp $O.$CONF $INSTALLDIR/$CONF

<../port/portmkfile

devfs.$O:	../port/devfs-posix.c
