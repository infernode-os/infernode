SYSTARG=Linux
OBJTYPE=${OBJTYPE:-arm64}
# Bypass mkconfig - include platform-specific files directly
SHELLTYPE=sh
OBJDIR=$SYSTARG/$OBJTYPE
<$ROOT/mkfiles/mkhost-$SYSTARG
<$ROOT/mkfiles/mkfile-$SYSTARG-$OBJTYPE

#Configurable parameters

CONF=emu			#default configuration
CONFLIST=emu
CLEANCONFLIST=

# GUI Backend Selection
# Options: headless, sdl3
# Default: sdl3 (Lucifer GUI via SDL3)
GUIBACK=sdl3

# GPU Acceleration (TensorRT/CUDA)
# Set ENABLEGPU=1 to build with GPU support (requires CUDA + TensorRT).
# Default: disabled. Only available on NVIDIA Jetson (arm64) at this stage.
ENABLEGPU=0

INSTALLDIR=$ROOT/$SYSTARG/$OBJTYPE/bin	#path of directory where kernel is installed

#end configurable parameters


<| AWK=$AWK $SHELLNAME ../port/mkdevlist  $CONF	#sets $IP, $DEVS, $PORT, $LIBS
<mkfile-$OBJTYPE	# sets $ARCHFILES

# Include GPU configuration (set ENABLEGPU=1 for Jetson TensorRT support)
<mkfile-gpu-$ENABLEGPU

# GUI backend variables (GUISRC, GUIFLAGS, GUILIBS)
# Included here for variable definitions only; build rules are below default target.
<mkfile-gui-$GUIBACK

# libfido2 for the #F (/dev/2fa) device. Conditional, same pattern as macOS and
# opus: define -DHAVE_FIDO2 and link -lfido2 only when libfido2 is present
# (apt install libfido2-dev), otherwise fido2bridge.c compiles its stub path so
# the emu still builds — /dev/2fa just reports "not built in".
FIDO2_CFLAGS=`{if pkg-config --exists libfido2 2>/dev/null; then echo -DHAVE_FIDO2; pkg-config --cflags libfido2; fi}
FIDO2_LIBS=`{if pkg-config --exists libfido2 2>/dev/null; then pkg-config --libs libfido2; fi}

OBJ=\
	asm-$OBJTYPE.$O\
	$ARCHFILES\
	os.$O\
	kproc-pthreads.$O\
	segflush-$OBJTYPE.$O\
	$GUISRC\
	$CONF.root.$O\
	lock.$O\
	$DEVS\
	$PORT\

#LIBNAMES=${LIBS:%=lib%.a}
#libs=${LIBS:%=$ROOT/$OBJDIR/lib/lib%.a}

HFILES=\

CFLAGS=\
	'-DROOT="'$ROOT'"'\
	-DEMU -I. -I../port\
	-I$ROOT/$SYSTARG/$OBJTYPE/include\
	-I$ROOT/include\
	-I$ROOT/libinterp\
	$CTHREADFLAGS $CFLAGS $EMUOPTIONS $GUIFLAGS $GPUFLAGS $FIDO2_CFLAGS\

KERNDATE=0

SYSLIBS=\
	$GPULIBS\
	-lm\
	-lpthread\

default:V:	$O.$CONF

$O.$CONF:	$OBJ $CONF.c $CONF.root.h # $LIBNAMES
	$CC $CFLAGS '-DKERNDATE='$KERNDATE $CONF.c
	$LD $LDFLAGS -o $target $OBJ $CONF.$O $LIBFILES $SYSLIBS $GUILIBS $FIDO2_LIBS

install:V: $O.$CONF
	cp $O.$CONF $INSTALLDIR/$CONF

<../port/portmkfile

devfs.$O:	../port/devfs-posix.c

# SDL3 backend compile rule (must be after default target)
draw-sdl3.$O: ../port/draw-sdl3.c
	$CC $CFLAGS $GUIFLAGS -I. ../port/draw-sdl3.c
