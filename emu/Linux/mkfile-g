SYSTARG=Linux
<$ROOT/mkconfig
SYSTARG=Linux

#Configurable parameters

CONF=emu			#default configuration
CONFLIST=emu
CLEANCONFLIST=

INSTALLDIR=$ROOT/$SYSTARG/$OBJTYPE/bin	#path of directory where kernel is installed

#end configurable parameters


<| $SHELLNAME ../port/mkdevlist  $CONF	#sets $IP, $DEVS, $PORT, $LIBS
<mkfile-$OBJTYPE	# sets $ARCHFILES

# libfido2 for the #F (/dev/2fa) device. Conditional: define -DHAVE_FIDO2 and
# link -lfido2 only when libfido2 is present (apt install libfido2-dev), else
# fido2bridge.c compiles its stub path so the headless emu still builds.
FIDO2_CFLAGS=`{if pkg-config --exists libfido2 2>/dev/null; then echo -DHAVE_FIDO2; pkg-config --cflags libfido2; fi}
FIDO2_LIBS=`{if pkg-config --exists libfido2 2>/dev/null; then pkg-config --libs libfido2; fi}

OBJ=\
	asm-$OBJTYPE.$O\
	$ARCHFILES\
	os.$O\
	kproc-pthreads.$O\
	segflush-$OBJTYPE.$O\
	stubs-headless.$O\
	$CONF.root.$O\
	lock.$O\
	$DEVS\
	$PORT\

#LIBNAMES=${LIBS:%=lib%.a}
#libs=${LIBS:%=$ROOT/$OBJDIR/lib/lib%.a}

HFILES=\

CFLAGS=\
	'-DROOT="'$ROOT'"'\
	-DEMU -I. -I../port\
	-I$ROOT/$SYSTARG/$OBJTYPE/include\
	-I$ROOT/include\
	-I$ROOT/libinterp\
	$CTHREADFLAGS $CFLAGS $EMUOPTIONS $FIDO2_CFLAGS\

KERNDATE=`{$NDATE}

# Headless build - no X11 needed
SYSLIBS=\
	-lm\
	-lpthread\

default:V:	$O.$CONF

$O.$CONF:	$OBJ $CONF.c $CONF.root.h # $LIBNAMES
	$CC $CFLAGS '-DKERNDATE='$KERNDATE $CONF.c
	$LD $LDFLAGS -o $target $OBJ $CONF.$O $LIBFILES $SYSLIBS $FIDO2_LIBS

install:V: $O.$CONF
	cp $O.$CONF $INSTALLDIR/$CONF

<../port/portmkfile

devfs.$O:	../port/devfs-posix.c
