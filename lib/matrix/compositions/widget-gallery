# widget-gallery — Tk widget review crystallisation
#
# One of every core Tk widget class, side by side: engine defaults on
# the left (raised/sunken bevels, text-tight targets), the proposed
# InferNode treatment on the right (flat 2D relief, padded touch
# surfaces via pack -ipadx/-ipady).  A review instrument for the
# toolkit's look, not a data view — load it, compare, decide the
# default treatment.
#
#     wm/matrix /lib/matrix/compositions/widget-gallery
# (demo-gallery.sh is that, self-contained)

layout vsplit 100 0

top tk-gallery /
