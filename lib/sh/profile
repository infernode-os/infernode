#!/dis/sh.dis
# InferNode shell initialization
load std

# Set command search path
path=(/dis .)

# Get username
user=`{cat /dev/user}


# ── Networking ──────────────────────────────────────────────
mount -ac {mntgen} /n >[2] /dev/null
bind -a '#I' /net >[2] /dev/null
ndb/cs

# ── Telephony / SMS (devphone) ──────────────────────────────
# /phone is the radio device tree (#f, emu/port/devphone.c). It only
# binds on hosts that HAVE a radio — i.e. iOS and Android, set up by
# lib/lucifer/boot-mobile.sh. Desktop hosts don't get an #f device
# (no stub, no silently-swallowed sends); to use a phone's telephony
# from a desktop, mount the phone's exported /phone over 9P:
#   mount -A 'tcp!<phone-ip>!<port>' /phone
# (the phone exports it via `listen -A 'tcp!*!<port>' {export /phone}`).
# Same userspace API; bytes travel across the wire to the radio.
# See docs/HELLAPHONE.md for the desktop-mount recipe.

# ── Host filesystem + home directory (early — needed for overlays) ──
# /n/local is the user-visible root of the host filesystem on every
# platform. Wiring to get there differs (POSIX has a single root;
# Windows has drive letters), but Inferno-side paths are identical.
if {~ $emuhost MacOSX Linux Nt}{
	if {~ $emuhost Nt} {
		# Windows: mount C:\ at /n/local. Profiles live at C:\Users\<name>,
		# so /n/local/Users/$user matches macOS's /n/local/Users/$user.
		trfs '#UC:/' /n/local >[2] /dev/null
		ls /n/local >[2] /dev/null		# settle the EXPASYNC export/mount before first use (host-root trfs race)
		ghome=/n/local/Users/^$user
	}{
		trfs '#U*' /n/local >[2] /dev/null
		ls /n/local >[2] /dev/null		# settle the EXPASYNC export/mount before first use (host-root trfs race)
		ghome=/n/local/^`{echo 'echo $HOME' | os sh}
	}
	home=$ghome

	# ── Writable overlay from ~/.infernode ──────────────────
	# User state (secstore, config, tmp) always goes to ~/.infernode,
	# regardless of whether this is a bundle, dev checkout, or headless.
	# The emu root stays clean — no user data mixed with system files.
	infhome=$ghome^/.infernode

	# Ensure every overlay SOURCE dir exists BEFORE the binds below. This runs
	# unconditionally (not gated on first-run): `bind -bc` of a missing source
	# silently falls back to the emu-root dir, so a deleted (or never-created)
	# ~/.infernode/usr/inferno/secstore would route secstore into the emu root /
	# bundle instead of the user's home — and 2FA enrollment would not persist.
	mkdir -p $infhome/usr/inferno/secstore
	mkdir -p $infhome/usr/inferno/tmp
	mkdir -p $infhome/lib/ndb
	mkdir -p $infhome/lib/lucifer/theme
	mkdir -p $infhome/lib/veltro
	mkdir -p $infhome/lib/veltro-agents
	mkdir -p $infhome/lib/veltro-keys
	mkdir -p $infhome/lib/keyring
	mkdir -p $infhome/tmp

	# First-run only: seed writable defaults from the emu root (don't clobber
	# a user's existing config on later boots).
	if {! ftest -f $infhome/lib/ndb/llm} {
		cp /lib/ndb/llm $infhome/lib/ndb/llm >[2] /dev/null
		cp /lib/lucifer/theme/current $infhome/lib/lucifer/theme/current >[2] /dev/null
		cp /lib/veltro/meta.txt $infhome/lib/veltro/meta.txt >[2] /dev/null
		cp /lib/veltro/agents/task.txt $infhome/lib/veltro-agents/task.txt >[2] /dev/null
	}

	# Writable overlay mounts
	bind -bc $infhome/usr/inferno/secstore /usr/inferno/secstore
	bind -bc $infhome/usr/inferno/tmp      /usr/inferno/tmp
	bind -bc $infhome/lib/ndb              /lib/ndb
	bind -bc $infhome/lib/lucifer/theme    /lib/lucifer/theme
	bind -bc $infhome/lib/veltro           /lib/veltro
	bind -bc $infhome/lib/veltro-agents    /lib/veltro/agents
	bind -bc $infhome/lib/veltro-keys      /lib/veltro/keys >[2] /dev/null
	mkdir -p /lib/keyring >[2] /dev/null
	bind -bc $infhome/lib/keyring          /lib/keyring >[2] /dev/null
	bind -bc $infhome/tmp /tmp >[2] /dev/null
}{
	# Non-desktop platforms (native hardware, embedded)
	home=/usr/^$user
	if {! ftest -d $home} { mkdir -p $home }
}

# ── Audit log (tamper-evident security log) — OFF by default ──
# Disabled unless opted in: most installs don't need it, and the emitters
# are no-ops while the log is unmounted, so "off" means simply not mounting.
# Enable (chain-only):   touch /usr/inferno/audit/on    (then mount below)
# Enable + signing:      sh /lib/sh/audit-setup         (factotum-held key)
# Disable:               rm /usr/inferno/audit/on; unmount /mnt/audit
# Mounted BEFORE the auth services so their events are captured (AU-2/AU-9).
# Compliance deployments require AU-2 logging — a hardened deployment sets
# the host env AUDITMODE=on (like CNSAMODE) to default it on without an
# operator step; the general build leaves it unset. See INFR-357 and
# doc/compliance/SP800-92-audit-log.md. Non-fatal: never blocks boot.
mkdir -p /usr/inferno/audit >[2] /dev/null
if {~ $emuhost MacOSX Linux}{
	auditmode=`{os sh -c 'if [ -n "$AUDITMODE" ]; then echo on; fi' >[2] /dev/null}
	if {~ $auditmode on} { touch /usr/inferno/audit/on >[2] /dev/null }
}
if {ftest -f /usr/inferno/audit/on} {
	mkdir -p /mnt/audit >[2] /dev/null
	mount {auditfs} /mnt/audit >[2] /dev/null
}

# ── Secstored (persistent encrypted key storage) ──────────
# Kill stale secstored from a previous emu session — a stale
# instance with different PAK data causes login to hang indefinitely.
if {~ $emuhost Nt} {
	# Windows: kill stale secstored — os without backticks (fire and forget)
	os cmd /c 'taskkill /F /IM secstored.exe >nul 2>&1' >[2] /dev/null
}{
	os sh -c 'lsof -ti :5356 2>/dev/null | xargs kill 2>/dev/null; sleep 1; true' >[2] /dev/null
}
mkdir -p /usr/inferno/secstore >[2] /dev/null
auth/secstored >[2] /dev/null &
sleep 1

# ── Factotum ──────────────────────────────────────────────
# Headless: if $SECSTORE_PASSWORD is set on the host, start factotum
# with secstore backing so all keys are loaded automatically.
# GUI: factotum starts empty; wm/logon unlocks secstore interactively.
if {! ftest -f /mnt/factotum/proto}{
	if {~ $emuhost Nt} {
		# Windows: secstore password not yet supported via env var
		# (os cmd in backticks hangs). Use GUI login or setup script.
		havesecpass=''
	}{
		havesecpass=`{os sh -c 'if [ -n "$SECSTORE_PASSWORD" ]; then echo yes; fi' >[2] /dev/null}
	}
	if {! ~ $#havesecpass 0} {
		secpass=`{os sh -c 'printf "%s" "$SECSTORE_PASSWORD"'}
		if {! ~ $#secpass 0} {
			if {! ~ $#user 0} {
				auth/factotum -S tcp!localhost!5356 -u $user -P $secpass
			}{
				auth/factotum -S tcp!localhost!5356 -P $secpass
			}
		}{
			auth/factotum
		}
	}{
		auth/factotum
	}
}

# Provision API keys into factotum (secstore is the persistent home; these are
# the CLI/CI fallbacks). Each service is sourced from its host env var
# <SERVICE>_API_KEY first, then the legacy plaintext file /lib/veltro/keys/<svc>.
# Add a service to the lists below to provision it the same way.
fn provisionkey {
	# $1 = service name, $2 = host env var
	_pk=`{os sh -c 'printf %s "${'^$2^'}"' >[2] /dev/null}
	if {~ $#_pk 0} {
		_pk=`{cat /lib/veltro/keys/$1 >[2] /dev/null}
	}
	if {! ~ $#_pk 0} {
		echo 'key proto=pass service='^$1^' user=apikey !password='^$_pk > /mnt/factotum/ctl >[2] /dev/null
	}
}
fn provisionkeyfile {
	# Windows: os sh in backticks hangs, so file-only. $1 = service name.
	_pk=`{cat /lib/veltro/keys/$1 >[2] /dev/null}
	if {! ~ $#_pk 0} {
		echo 'key proto=pass service='^$1^' user=apikey !password='^$_pk > /mnt/factotum/ctl >[2] /dev/null
	}
}
if {~ $emuhost Nt} {
	provisionkeyfile anthropic
	provisionkeyfile brave
	provisionkeyfile openai
}{
	provisionkey anthropic ANTHROPIC_API_KEY
	provisionkey brave BRAVE_API_KEY
	provisionkey openai OPENAI_API_KEY
}

# ── LLM + Speech (desktop platforms) ──────────────────────
if {~ $emuhost MacOSX Linux Nt}{
	llmmode=`{sed -n 's/^mode=//p' /lib/ndb/llm >[2] /dev/null}
	if {~ $llmmode remote} {
		llmdial=`{sed -n 's/^dial=//p' /lib/ndb/llm}
		llmauth=`{sed -n 's/^auth=//p' /lib/ndb/llm >[2] /dev/null}
		llmkey=`{sed -n 's/^keyfile=//p' /lib/ndb/llm >[2] /dev/null}
		if {~ $llmkey ''} { llmkey=/lib/keyring/serve-llm }
		# Background: 9P mount has no protocol-level timeout, and the
		# remote export can degrade to "accepts TCP, never reads
		# TVERSION". A foreground mount in that state wedges boot.
		# See docs/postmortems/2026-05-04-local-boot-decoupled-from-remote-llm.md
		if {~ $llmauth keyring} {
			if {ftest -f $llmkey} {
				mount -k $llmkey $llmdial /mnt/llm >[2] /dev/null &
			}{
				echo 'profile: keyring auth requested but keyfile not found at' $llmkey
			}
		}{
			mount -A $llmdial /mnt/llm >[2] /dev/null &
		}
	}{
		llmbackend=`{sed -n 's/^backend=//p' /lib/ndb/llm >[2] /dev/null}
		llmurl=`{sed -n 's/^url=//p' /lib/ndb/llm >[2] /dev/null}
		llmmodel=`{sed -n 's/^model=//p' /lib/ndb/llm >[2] /dev/null}
		# backend=cli is the host-side CLI gateway (claude-gate) —
		# OpenAI-shaped on localhost, so llmsrv dials it the same way.
		if {~ $llmbackend openai cli} {
			llmsrv -b openai -u $llmurl -M $llmmodel >[2] /dev/null &
		}{
			if {! ~ $llmmodel ''} {
				llmsrv -M $llmmodel >[2] /dev/null &
			}{
				llmsrv >[2] /dev/null &
			}
		}
	}

	# Start speech file server (TTS/STT via /n/speech)
	/dis/veltro/speech9p.dis -e cmd &
}{
	# Non-desktop: mount remote llm9p
	mount -A 'tcp!llmserver!5640' /mnt/llm >[2] /dev/null
}

# ── tmp setup ─────────────────────────────────────────────
if {! ftest -d $home/tmp} {
	mkdir -p $home/tmp
}
mkdir -p /tmp >[2] /dev/null
bind -bc $home/tmp /tmp >[2] /dev/null

# Clean stale temp files from previous sessions
for f in /tmp/*.????xenith /tmp/*.????acme /tmp/*.????blks {
	rm $f >[2] /dev/null
}

cd $home
