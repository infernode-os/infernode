#!/dis/sh.dis
# Lean Inferno profile for headless service serving.
#
# Strips everything not needed to mount /n/llm and export it over 9P:
# no secstored, no factotum, no Veltro overlays, no theme bindings,
# no ~/.infernode seed, no /tmp setup, no speech9p.
#
# Started by serve-llm.sh on the host:
#   emu -c1 -r$ROOT sh /lib/sh/serve-profile
#
# Listen-side authentication mode is read from the host environment via
# `os sh`:
#   SERVE_LLM_AUTH=keyring   (default; requires keyfile)
#   SERVE_LLM_AUTH=anon      (--anon-lan opt-in; preserves pre-INFR-16 behaviour)
#   SERVE_LLM_KEY=<path>     (in-emu path to the signer keyfile; default /lib/keyring/serve-llm)
# These are set by serve-llm.sh; never edit this profile to flip them.

load std
path=(/dis .)

# в”Ђв”Ђ Networking (mntgen + IP stack + connection server) в”Ђв”Ђв”Ђв”Ђв”Ђ
mount -ac {mntgen} /n
bind -a '#I' /net
ndb/cs

# в”Ђв”Ђ Host filesystem (read-only is fine for the daemon) в”Ђв”Ђв”Ђв”Ђв”Ђ
trfs '#U*' /n/local

# в”Ђв”Ђ Bind user config over /lib/ndb (same backend/model the desktop
#    uses) and /lib/keyring (signer keys) into the in-emu namespace. в”Ђв”Ђ
ghome=/n/local/^`{echo 'echo $HOME' | os sh}
infhome=$ghome^/.infernode
if {ftest -d $infhome/lib/ndb} {
	bind -bc $infhome/lib/ndb /lib/ndb
}
if {ftest -d $infhome/lib/keyring} {
	mkdir -p /lib/keyring >[2] /dev/null
	bind -bc $infhome/lib/keyring /lib/keyring
}

# в”Ђв”Ђ LLM backend switcher control plane (/llm/{ctl,status}) в”Ђв”Ђ
# llmctl9p serves a tiny synthetic FS that lets anything in the
# emu namespace switch the local LLM backend (Ollama/SGLang/none)
# by writing a verb to /llm/ctl. The daemon delegates the actual
# systemctl + ndb work to the host `llmctl` bash tool via os(1).
#
# Host binary path comes from $LLMCTL_BIN if set, otherwise the
# unqualified "llmctl" which `os` resolves against the host PATH.
# Skip silently if the .dis is missing вЂ” the headless gateway still
# serves with the existing /lib/ndb/llm contents; only the dynamic
# switch is unavailable.
mkdir -p /llm >[2] /dev/null
if {ftest -f /dis/llmctl9p.dis} {
	llmctlbin=`{os sh -c 'printf %s "${LLMCTL_BIN:-llmctl}"'}
	mount {/dis/llmctl9p.dis -b $llmctlbin} /llm
}{
	echo 'serve-profile: NOTE /dis/llmctl9p.dis missing - /llm switcher disabled'
}

# в”Ђв”Ђ LLM service (mounts /n/llm) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
llmbackend=`{sed -n 's/^backend=//p' /lib/ndb/llm}
llmurl=`{sed -n 's/^url=//p' /lib/ndb/llm}
llmmodel=`{sed -n 's/^model=//p' /lib/ndb/llm}

if {~ $llmbackend openai} {
	# -r low: reasoning_effort default for o1-style / gpt-oss models.
	# Per InferNode MODEL-EVAL: low gives ~15Г— speedup on tool-driven
	# scenarios with no quality loss vs default medium. Devstral and
	# Anthropic backends ignore the field вЂ” safe to set unconditionally.
	llmsrv -D -b openai -u $llmurl -M $llmmodel -r low &
}{
	if {! ~ $llmmodel ''} {
		llmsrv -D -M $llmmodel &
	}{
		llmsrv -D &
	}
}

# Wait for llmsrv to finish its self-mount of /n/llm
sleep 2

# в”Ђв”Ђ 9P export в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Default: keyring auth (Inferno Ed25519 signer). Clients dial with
#   mount -k <keyfile> tcp!host!5640 /n/llm
# --anon-lan: anonymous attach (-A), the pre-INFR-16 default. Only safe
# on a trusted network (LAN, ZeroTier with strict ACLs, VPN).
# -s: synchronous, blocks here so emu stays alive while listening.
# {export /n/llm &}: fork the export so listen's accept loop can take
# the next connection immediately. Without the &, listen runs export
# inline and blocks until that single client disconnects вЂ” a second
# mount attempt then silently hangs at TVERSION. The & makes export
# a child; each new connect spawns its own export against the shared
# /n/llm namespace.
#
# Mode is read from the host environment via `os sh`. serve-llm.sh
# always exports both vars (defaults baked in there), so we don't try
# to apply ${VAR:-default} fallbacks here вЂ” rc's quoting and brace
# parsing make that fragile.
authmode=`{os sh -c 'printf %s "$SERVE_LLM_AUTH"'}
keyfile=`{os sh -c 'printf %s "$SERVE_LLM_KEY"'}
if {~ $authmode anon} {
	echo 'serve-profile: WARNING listen mode anon (--anon-lan) - no authentication'
	listen -sA 'tcp!*!5640' {export /n/llm &}
}{
	if {! ftest -f $keyfile} {
		echo 'serve-profile: ERROR keyring auth requested but keyfile not found at' $keyfile
		echo 'serve-profile: generate one with: serve-llm.sh --gen-key'
		echo 'serve-profile: or pass --anon-lan to listen without authentication'
		exit fail
	}
	echo 'serve-profile: listen mode keyring keyfile' $keyfile
	listen -s -k $keyfile 'tcp!*!5640' {export /n/llm &}
}
