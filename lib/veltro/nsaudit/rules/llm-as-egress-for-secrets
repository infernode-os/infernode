rule=LLM_AS_EGRESS_FOR_SECRETS
	severity=high
	require='sends_llm reads_secrets_factotum'
	message='The agent can read factotum secrets and send to an LLM. Secret material can leave the machine inside a prompt, bypassing network path restrictions.'
	fix='remove /mnt/factotum from caps.paths, or remove the LLM-sending tool'
