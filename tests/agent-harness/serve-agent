#!/dis/sh.dis
# ─────────────────────────────────────────────────────────────────
# TESTING HARNESS ONLY — NEVER SHIP IN A RELEASE.
#
# CI enforces this:
#   .github/workflows/release.yml refuses to package any file whose
#     name matches serve-agent* or whose path contains agent-harness.
#   .github/workflows/ci.yml refuses any commit that places such a
#     file outside tests/agent-harness/.
#
# Move this file at your peril — see CLAUDE.md "ring-fence rule".
# ─────────────────────────────────────────────────────────────────
#
# Agent-surface gateway for the external evaluation harness.
#
# Sits between serve-profile (which exports just /mnt/llm) and the
# full GUI boot (which starts lucifer and binds X/SDL3). This
# profile starts the headless agent stack and exports both:
#   tcp!127.0.0.1!5640 → /mnt/llm (LLM session gateway, llmsrv)
#   tcp!127.0.0.1!5641 → /mnt/ui  (activity / conversation surface, luciuisrv)
#
# Localhost binding is intentional: the harness lives on the same
# host as emu, and the keyring keyfile is not designed for distribution.
# See the "Three defensible postures" section of the design discussion.
#
# Started by tests/agent-harness/serve-agent.sh on the host:
#   emu -c1 -r$ROOT sh /tests/agent-harness/serve-agent
#
# Auth env is read from the host environment via `os sh` — set by
# serve-agent.sh, shape mirrors serve-profile.

load std
path=(/dis .)

# ── Networking (mntgen + IP stack + connection server) ─────
mount -ac {mntgen} /n
bind -a '#I' /net
ndb/cs

# ── Host filesystem (read-only) ─────
trfs '#U*' /n/local

# ── Bind user config over /lib/ndb (LLM backend selection) and
#    /lib/keyring (signer keys). Shared with serve-profile so the
#    same keyfile authenticates both /mnt/llm and /mnt/ui mounts. ──
ghome=/n/local/^`{echo 'echo $HOME' | os sh}
infhome=$ghome^/.infernode
if {ftest -d $infhome/lib/ndb} {
	bind -bc $infhome/lib/ndb /lib/ndb
}
if {ftest -d $infhome/lib/keyring} {
	mkdir -p /lib/keyring >[2] /dev/null
	bind -bc $infhome/lib/keyring /lib/keyring
}

# ── LLM backend switcher (optional — same as serve-profile) ──
mkdir -p /llm >[2] /dev/null
if {ftest -f /dis/llmctl9p.dis} {
	llmctlbin=`{os sh -c 'printf %s "${LLMCTL_BIN:-llmctl}"'}
	mount {/dis/llmctl9p.dis -b $llmctlbin} /llm
}

# ── LLM service (mounts /mnt/llm) ─────
llmbackend=`{sed -n 's/^backend=//p' /lib/ndb/llm}
llmurl=`{sed -n 's/^url=//p' /lib/ndb/llm}
llmmodel=`{sed -n 's/^model=//p' /lib/ndb/llm}

if {~ $llmbackend openai} {
	llmsrv -D -b openai -u $llmurl -M $llmmodel -r low &
}{
	if {! ~ $llmmodel ''} {
		llmsrv -D -M $llmmodel &
	}{
		llmsrv -D &
	}
}

# Wait for llmsrv to finish its self-mount of /mnt/llm
sleep 2

# ── Wallet service (needed by the keyring tool) ─────
/dis/veltro/wallet9p.dis >[2] /dev/null &
sleep 1

# ── UI service (mounts /mnt/ui) ─────
# luciuisrv is the same 9P fileserver the GUI mounts; the harness drives
# it as a client. No GUI, no SDL, no window manager.
luciuisrv
echo activity create Main > /mnt/ui/ctl
sleep 1

# ── tools9p: mount /tool with the same tool surface the desktop uses ─────
# The -b set is the full delegation budget; -p is the tool slice for
# activity 0 (the meta-agent). Matches lib/lucifer/boot.sh so harness
# scenarios see the same agent capabilities a desktop user would.
/dis/veltro/tools9p -v -m /tool -b read,list,find,search,grep,write,edit,exec,launch,spawn,diff,json,webfetch,git,say,editor,fractal,memory,todo,plan,websearch,mail,keyring,present,gap,limbo -p /dis/wm read list find present say hear task memory gap keyring editor shell limbo

# ── lucibridge for activity 0 ─────
lucibridge -a 0 -v -s >[2] /tmp/lucibridge.log &
sleep 1
echo 'create id=tasks type=taskboard label=Tasks' > /mnt/ui/activity/0/presentation/ctl

# ── 9P export: /mnt/llm and /mnt/ui, both localhost-bound ─────
# Auth mode is read from the host environment via `os sh`. serve-agent.sh
# always exports both vars (defaults baked in there). Same as serve-profile.
authmode=`{os sh -c 'printf %s "$SERVE_LLM_AUTH"'}
keyfile=`{os sh -c 'printf %s "$SERVE_LLM_KEY"'}

if {~ $authmode anon} {
	echo 'serve-agent: WARNING listen mode anon (--anon-lan) - no authentication'
	listen -A 'tcp!127.0.0.1!5640' {export /mnt/llm &} &
	listen -sA 'tcp!127.0.0.1!5641' {export /mnt/ui &}
}{
	if {! ftest -f $keyfile} {
		echo 'serve-agent: ERROR keyring auth requested but keyfile not found at' $keyfile
		echo 'serve-agent: generate one with: serve-llm.sh --gen-key (shared keyfile)'
		echo 'serve-agent: or pass --anon-lan to listen without authentication'
		exit fail
	}
	echo 'serve-agent: listen mode keyring keyfile' $keyfile
	listen -k $keyfile 'tcp!127.0.0.1!5640' {export /mnt/llm &} &
	listen -s -k $keyfile 'tcp!127.0.0.1!5641' {export /mnt/ui &}
}
